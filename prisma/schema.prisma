generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model DrawingConversation {
  id              String          @id @default(cuid())
  ownerScope      String
  title           String
  status          String          @default("empty")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  drawing         Drawing?
  messages        DrawingMessage[]

  @@index([ownerScope, updatedAt])
}

model DrawingMessage {
  id             String             @id @default(cuid())
  conversationId String
  ownerScope     String
  type           String
  role           String
  payload        Json
  createdAt      DateTime           @default(now())
  conversation   DrawingConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Drawing {
  id               String             @id @default(cuid())
  conversationId   String             @unique
  ownerScope       String
  originalFilename String
  safeFilename     String
  storageKey       String             @unique
  sourceType       String
  byteSize         Int
  status           String             @default("uploaded")
  previewImageUrl  String?
  previewWidth     Int?
  previewHeight    Int?
  previewTiles     Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  conversation     DrawingConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  analysisJob      AnalysisJob?
  components       ComponentCandidate[]
  physicalDevices  PhysicalDevice[]
  bomItems         BomItem[]
  exports          DrawingExport[]
}

model AnalysisJob {
  id         String   @id @default(cuid())
  drawingId  String   @unique
  status     String   @default("queued")
  progress   Int      @default(0)
  stage      String   @default("Queued")
  errorCode  String?
  errorMessage String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  drawing    Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
}

model ComponentCandidate {
  id                String   @id @default(cuid())
  drawingId         String
  temporaryId       String
  category          String
  tag               String?
  description       String
  specifications    Json
  manufacturer      String?
  modelNumber       String?
  confidence        Float
  evidence          Json
  method            String
  sourceTileId      String?
  physicalDeviceId  String?
  location          Json
  reviewStatus      String   @default("requires_review")
  originalCategory  String?
  correctedCategory String?
  removedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  drawing           Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  physicalDevice    PhysicalDevice? @relation(fields: [physicalDeviceId], references: [id], onDelete: SetNull)

  @@unique([drawingId, temporaryId])
  @@index([drawingId, reviewStatus])
}

model PhysicalDevice {
  id             String   @id @default(cuid())
  drawingId      String
  temporaryId    String
  tag            String?
  category       String
  description    String
  manufacturer   String?
  modelNumber    String?
  specifications Json
  confidence     Float
  evidence       Json
  reviewStatus   String
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  drawing        Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  occurrences    ComponentCandidate[]

  @@unique([drawingId, temporaryId])
  @@index([drawingId, reviewStatus])
}

model BomItem {
  id            String   @id @default(cuid())
  drawingId     String
  itemNumber    Int
  category      String
  description   String
  manufacturer  String?
  modelNumber   String?
  specifications Json
  quantity      Int
  confidence    Float
  reviewStatus  String
  generatedAt   DateTime @default(now())
  drawing       Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)

  @@index([drawingId, itemNumber])
}

model DrawingExport {
  id          String   @id @default(cuid())
  drawingId   String
  kind        String
  status      String
  filename    String
  createdAt   DateTime @default(now())
  drawing     Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
}
